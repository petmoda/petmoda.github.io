---
import { ACTIVITIES } from '../data/activities'
import SectionHeader from './SectionHeader.astro'
---

<section class="bg-background py-16 px-5 md:py-24 md:px-10" id="atividades">
  <div class="mx-auto max-w-7xl">
    <SectionHeader eyebrow="Projetos e Eventos" title="Atividades" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {
        ACTIVITIES.map((activity) => (
          <div class="flex flex-col reveal">
            <div
              class="ativ-placeholder"
              style={{ background: activity.gradient }}
            >
              <span>Imagem</span>
            </div>
            <div class="pt-5">
              <span class="ativ-tag">{activity.tag}</span>
              <h3 class="ativ-name">{activity.name}</h3>
              <p class="ativ-desc">{activity.description}</p>
              <a href={activity.href} class="ativ-btn">
                Saiba mais
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ativ-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    border: 1.5px solid #000;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1rem;
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    position: relative;
    overflow: hidden;
  }

  .ativ-placeholder::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.5) 0%, transparent 60%);
  }

  .ativ-placeholder span {
    position: relative;
    z-index: 1;
  }

  .ativ-tag {
    font-family: var(--font-display);
    font-size: 0.54rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.4rem;
  }

  .ativ-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .ativ-desc {
    font-size: 0.85rem;
    line-height: 1.8;
    color: #555;
  }

  .ativ-btn {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-foreground);
    padding-bottom: 2px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }
  .ativ-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
