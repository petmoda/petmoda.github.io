---
const year = new Date().getFullYear()
---

<footer class="bg-black text-white pt-18 pb-10 px-5 md:px-10">
  <div class="mx-auto max-w-7xl">
    <div
      class="grid grid-cols-1 gap-8 pb-12 border-b border-white/8 mb-8
      md:grid-cols-[1.2fr_1fr_1fr] md:gap-16"
    >
      <div>
        <span class="footer-logo-name">Petmoda</span>
        <span class="footer-logo-sub">Design-Moda · UFC</span>
        <p class="footer-desc">
          Grupo de pesquisa tutorial em Design-Moda da Universidade Federal do
          Ceará. Fortaleza, Ceará — Brasil.
        </p>
      </div>

      <div>
        <span class="footer-col-title">Navegação</span>
        <ul class="list-none flex flex-col gap-[0.65rem]">
          <li><a href="#sobre" class="footer-link">Sobre nós</a></li>
          <li><a href="#anais" class="footer-link">Produção científica</a></li>
          <li><a href="#atividades" class="footer-link">Atividades</a></li>
          <li><a href="#editais" class="footer-link">Editais</a></li>
          <li><a href="#membros" class="footer-link">Membros</a></li>
        </ul>
      </div>

      <div>
        <span class="footer-col-title">Contato</span>
        <ul class="list-none flex flex-col gap-[0.65rem]">
          <li>
            <a href="mailto:petmoda@ufc.br" class="footer-link">
              petmoda@ufc.br
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/petmoda_ufc"
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              @petmoda_ufc
            </a>
          </li>
          <li>
            <a
              href="https://maps.google.com/?q=Campus+do+Benfica,+Fortaleza+CE"
              class="footer-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              Campus do Benfica, Fortaleza – CE
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col gap-2 text-center
                md:flex-row md:justify-between md:items-center md:text-left"
    >
      <span class="footer-copy">
        © {year} PET Moda UFC. Todos os direitos reservados.
      </span>
      <span class="footer-ufc">Universidade Federal do Ceará</span>
    </div>
  </div>
</footer>

<style>
  .footer-logo-name {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.4rem;
    letter-spacing: 0.38em;
    color: #fff;
    display: block;
    margin-bottom: 0.25rem;
  }

  .footer-logo-sub {
    font-family: var(--font-display);
    font-size: 0.5rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    display: block;
    margin-bottom: 1.25rem;
  }

  .footer-desc {
    font-size: 0.8rem;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer-col-title {
    font-family: var(--font-display);
    font-size: 0.55rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    display: block;
    margin-bottom: 1.25rem;
  }

  .footer-link {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .footer-copy {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.2);
  }

  .footer-ufc {
    font-family: var(--font-display);
    font-size: 0.5rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.18);
  }
</style>
